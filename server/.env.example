# Server Config
NODE_ENV=development
PORT=5000

# Frontend URLs (For CORS)
FRONTEND_URL_DEV=http://localhost:5173
FRONTEND_URL_PROD=https://inkcuba.com

# Database
MONGO_URI=

# Auth (JWT_SECRET required in production)
JWT_SECRET=
JWT_ACCESS_EXPIRY=1d
JWT_REFRESH_EXPIRY=7d
EMAIL_VERIFY_EXPIRY_HOURS=24
PASSWORD_RESET_EXPIRY_HOURS=1

# MinIO Config
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=
MINIO_BUCKET_NAME=inkcuba-portfolios


# Email (SMTP) for verification and password reset
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=unosega@gmail.com
SMTP_PASS=
SMTP_FROM=unosega@gmail.com

# Seed: first admin user (optional; dev defaults used if not set)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Inkcuba Admin


