# Server
NODE_ENV=development
PORT=5000

# MongoDB (required in production)
MONGO_URI=mongodb://localhost:27017/inkcuba

# Frontend URL for CORS (no trailing slash)
FRONTEND_URL_DEV=http://localhost:5173
FRONTEND_URL_PROD=

# MinIO (optional; server runs without it if not set)
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_NAME=inkcuba-portfolios

# Auth (JWT_SECRET required in production)
JWT_SECRET=your-super-secret-key-min-32-chars
JWT_ACCESS_EXPIRY=7d
JWT_REFRESH_EXPIRY=30d
EMAIL_VERIFY_EXPIRY_HOURS=24
PASSWORD_RESET_EXPIRY_HOURS=1

# Email (SMTP) for verification and password reset
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Seed: first admin user (optional; dev defaults used if not set)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Inkcuba Admin
